{
  "$schema": "https://raw.githubusercontent.com/nicerdicer/tauri-v2-schema/main/tauri.conf.json",
  "productName": "Skills Validation",
  "version": "0.2.0",
  "identifier": "com.nonbytes.skills-validation",
  "build": {
    "frontendDist": "../src",
    "beforeDevCommand": "npm run build:css",
    "beforeBuildCommand": "npm run build:css"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Skills Validation",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "deb", "appimage", "msi", "nsis"],
    "icon": [
      "icons/icon_32.png",
      "icons/icon_128.png",
      "icons/icon_256.png",
      "icons/icon_512.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
